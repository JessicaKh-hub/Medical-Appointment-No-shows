   "source": [
    "# Order each patient's appointments chronologically (by when the visit actually happened)\n",
    "df = df.sort_values([\"patient_id\", \"appointment_day\"]).reset_index(drop=True)\n",
    "\n",
    "# Per-row no-show indicator (1 = this appointment was missed)\n",
    "no_show_flag = (df[\"showed_up\"] == 0).astype(int)\n",
    "\n",
    "# Count no-shows that happened BEFORE the current appointment, per patient.\n",
    "# cumsum() runs the total including the current row, so subtract the current row to exclude it.\n",
    "df[\"prior_no_shows\"] = no_show_flag.groupby(df[\"patient_id\"]).cumsum() - no_show_flag\n",
    "\n",
    "# History flags now use only PAST behaviour\n",
    "df[\"ever_no_show\"]     = (df[\"prior_no_shows\"] > 0).astype(int)\n",
    "df[\"frequent_no_show\"] = (df[\"prior_no_shows\"] >= 2).astype(int)\n",
    "\n",
    "df.head(10)"
   ]
  },
